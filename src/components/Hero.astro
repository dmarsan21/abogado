---
import { Image } from 'astro:assets';
import heroBg from '../assets/hero-bg.png';
---

<section id="inicio" class="relative pt-32 pb-20 md:pt-48 md:pb-32 overflow-hidden flex items-center min-h-[90vh] bg-brand-navy">

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 items-center">
      
      <!-- Columna de Texto -->
      <div class="order-1 md:order-1 pt-8 md:pt-0">
        <div class="flex items-center mb-8">
          <div class="w-10 h-[1px] bg-brand-gold mr-4"></div>
          <span class="text-brand-gold text-xs font-semibold tracking-[0.2em] uppercase">Despacho de Abogados</span>
        </div>
        
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold text-white leading-[1.15] mb-8">
          Compromiso Legal, <br/>
          <span class="text-brand-gold italic font-normal">Resultados Sólidos.</span>
        </h1>
        
        <p class="text-lg text-gray-300 mb-12 max-w-lg font-light leading-relaxed">
          Especialistas en Derecho Civil, Familiar y Corporativo en la ciudad de Puebla. Representación ética y estratégica de alto nivel para proteger su patrimonio.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-5">
          <a href="#contacto" class="inline-flex justify-center items-center px-8 py-4 bg-brand-gold text-[#111827] text-sm uppercase tracking-widest font-bold hover:bg-brand-gold-hover hover:scale-[1.02] transition-all duration-300 shadow-xl">
            Agendar Consulta
          </a>
          <a href="#servicios" class="inline-flex justify-center items-center px-8 py-4 bg-transparent border border-white/30 text-white text-sm uppercase tracking-widest font-semibold hover:border-white hover:bg-white/5 transition-colors duration-300">
            Áreas de Práctica
          </a>
        </div>
      </div>
      
      <!-- Columna de Imagen -->
      <div class="relative order-2 md:order-2 mt-8 md:mt-0">
        <div class="relative w-full aspect-[4/5] z-10 rounded-2xl overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.3)] border border-white/10 md:-ml-8 lg:-ml-12 transform md:translate-y-8">
          <Image 
            src={heroBg} 
            alt="Oficinas legales corporativas de Martínez & Asociados en Puebla" 
            class="w-full h-full object-cover object-center"
            format="webp"
            quality={90}
          />
        </div>
        <!-- Decoración geométrica sutil -->
        <div class="absolute -bottom-6 -right-6 w-32 h-32 border-b-2 border-r-2 border-brand-gold/30 z-0 rounded-br-3xl hidden md:block"></div>
      </div>
      
    </div>
  </div>
</section>
