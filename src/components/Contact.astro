---
---

<section id="contacto" class="py-32 bg-white relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="flex flex-col lg:flex-row bg-white border border-gray-100 shadow-[0_10px_60px_rgba(0,0,0,0.05)] overflow-hidden">
      
      <!-- Información de Contacto -->
      <div class="lg:w-2/5 p-12 lg:p-16 flex flex-col justify-between border-b lg:border-b-0 lg:border-r border-gray-100 bg-brand-gray-bg">
        
        <div class="relative z-10">
          <div class="w-10 h-[1px] bg-brand-gold mb-6"></div>
          <h3 class="text-3xl font-serif font-bold text-brand-navy mb-4">Agende su Consulta</h3>
          <p class="text-gray-500 mb-12 text-sm leading-relaxed font-light">
            Dé el primer paso hacia la resolución de su caso. Nuestros especialistas analizarán su situación con absoluta confidencialidad y rigor ético.
          </p>
          
          <div class="space-y-10">
            <div class="flex items-start gap-5">
              <svg class="w-5 h-5 text-brand-gold mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              <div>
                <p class="font-serif text-brand-navy text-sm font-bold tracking-widest uppercase mb-1">Contacto Directo</p>
                <p class="text-gray-600 font-light">+00 (000) 000 0000</p>
              </div>
            </div>
            
            <div class="flex items-start gap-5">
              <svg class="w-5 h-5 text-brand-gold mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              <div>
                <p class="font-serif text-brand-navy text-sm font-bold tracking-widest uppercase mb-1">Correspondencia</p>
                <p class="text-gray-600 font-light">contacto@martinez-asociados.com</p>
              </div>
            </div>
            
            <div class="flex items-start gap-5">
              <svg class="w-5 h-5 text-brand-gold mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              <div>
                <p class="font-serif text-brand-navy text-sm font-bold tracking-widest uppercase mb-1">Nuestras Oficinas</p>
                <p class="text-gray-600 font-light leading-relaxed">Edificio Corporativo Demo, Piso 0<br/>Av. Principal 0000, Colonia Ficticia<br/>Ciudad de Demostración, C.P. 00000</p>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Formulario -->
      <div class="lg:w-3/5 p-12 lg:p-16 bg-white">
        <form id="contact-form" class="space-y-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
              <label for="nombre" class="block text-xs font-semibold tracking-widest text-brand-navy mb-3 uppercase">Nombre Completo</label>
              <input type="text" id="nombre" name="nombre" required class="w-full px-0 py-3 bg-transparent border-b border-gray-200 focus:border-brand-gold outline-none transition-colors text-brand-navy placeholder-gray-400" placeholder="Ej. Juan Pérez" />
            </div>
            <div>
              <label for="telefono" class="block text-xs font-semibold tracking-widest text-brand-navy mb-3 uppercase">Teléfono de Contacto</label>
              <input type="tel" id="telefono" name="telefono" required class="w-full px-0 py-3 bg-transparent border-b border-gray-200 focus:border-brand-gold outline-none transition-colors text-brand-navy placeholder-gray-400" placeholder="000 000 0000" />
            </div>
          </div>
          
          <div>
            <label for="email" class="block text-xs font-semibold tracking-widest text-brand-navy mb-3 uppercase">Correo Electrónico</label>
            <input type="email" id="email" name="email" required class="w-full px-0 py-3 bg-transparent border-b border-gray-200 focus:border-brand-gold outline-none transition-colors text-brand-navy placeholder-gray-400" placeholder="su@correo.com" />
          </div>
          
          <div>
            <label for="area" class="block text-xs font-semibold tracking-widest text-brand-navy mb-3 uppercase">Asunto Legal</label>
            <div class="relative">
              <select id="area" name="area" class="w-full px-0 py-3 bg-transparent border-b border-gray-200 focus:border-brand-gold outline-none transition-colors text-brand-navy appearance-none cursor-pointer">
                <option value="" disabled selected class="text-gray-400">Seleccione el área de interés...</option>
                <option value="familiar" class="text-brand-navy">Derecho Familiar</option>
                <option value="civil" class="text-brand-navy">Derecho Civil</option>
                <option value="penal" class="text-brand-navy">Defensa Penal</option>
                <option value="corporativo" class="text-brand-navy">Asesoría Corporativa</option>
              </select>
              <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center text-brand-gold">
                <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
              </div>
            </div>
          </div>
          
          <div class="pt-6">
            <button type="submit" class="w-full py-5 bg-brand-navy text-white text-sm tracking-widest uppercase font-bold hover:bg-brand-navy-dark transition-colors duration-300 shadow-md">
              Solicitar Evaluación de Caso
            </button>
          </div>
          
          <p id="form-message" class="text-sm text-center hidden mt-4 font-serif italic text-brand-navy"></p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const formMessage = document.getElementById('form-message');

  if (form && formMessage) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = submitBtn.textContent;
      
      submitBtn.disabled = true;
      submitBtn.textContent = 'PROCESANDO...';
      submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
      
      setTimeout(() => {
        form.reset();
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
        submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
        
        formMessage.textContent = 'Su mensaje ha sido recibido con éxito. Nos pondremos en contacto a la brevedad.';
        formMessage.classList.remove('hidden');
        
        setTimeout(() => {
          formMessage.classList.add('hidden');
        }, 6000);
      }, 1500);
    });
  }
</script>
