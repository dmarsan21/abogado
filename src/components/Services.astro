---
const services = [
  {
    title: "Derecho Familiar",
    description: "Manejo discreto y humano en asuntos de Divorcios, Pensiones Alimenticias, Custodias y Adopciones, protegiendo siempre la integridad del núcleo familiar.",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>`
  },
  {
    title: "Derecho Civil",
    description: "Resolución efectiva en conflictos de Contratos, Propiedades, Sucesiones e Intestados. Salvaguardamos su patrimonio con firmeza y profundo conocimiento.",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>`
  },
  {
    title: "Defensa Penal",
    description: "Representación estratégica, ética y contundente en averiguaciones y procesos penales, garantizando el respeto irrestricto a los derechos de nuestros clientes.",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"></path></svg>`
  },
  {
    title: "Asesoría Corporativa",
    description: "Constitución de empresas, diseño de actas constitutivas, auditoría legal y contratos comerciales. Cimientos robustos para el crecimiento corporativo seguro.",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>`
  }
];
---

<section id="servicios" class="py-32 bg-brand-gray-bg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-24">
      <div class="flex items-center justify-center mb-6">
        <div class="w-12 h-[1px] bg-brand-gold"></div>
        <span class="mx-4 text-brand-gold text-xs font-semibold tracking-[0.2em] uppercase">Especialidades</span>
        <div class="w-12 h-[1px] bg-brand-gold"></div>
      </div>
      <h2 class="text-3xl md:text-5xl font-serif font-bold text-brand-navy mb-8">Nuestras Áreas de Práctica</h2>
      <p class="text-lg text-gray-600 font-light leading-relaxed">
        Contamos con especialistas dedicados en cada rubro para brindar una asesoría jurídica integral y ética, enfocada en salvaguardar sus intereses con la mayor pulcritud comercial y civil.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-10">
      {services.map(service => (
        <div class="bg-white p-12 rounded-sm border border-gray-100 shadow-[0_5px_40px_rgba(0,0,0,0.03)] hover:shadow-[0_10px_50px_rgba(0,0,0,0.06)] hover:border-brand-gold transition-all duration-300 group flex flex-col sm:flex-row gap-8 items-start">
          <div class="flex-shrink-0">
            <div class="text-brand-navy group-hover:text-brand-gold transition-colors duration-300">
              <Fragment set:html={service.icon} />
            </div>
          </div>
          <div>
            <h3 class="text-2xl font-serif font-bold text-brand-navy mb-4 group-hover:text-brand-gold transition-colors duration-300">{service.title}</h3>
            <p class="text-gray-500 font-light leading-relaxed text-sm">
              {service.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
